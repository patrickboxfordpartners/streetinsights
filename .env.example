# Supabase (VITE_ prefix required for frontend)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase direct Postgres connection (worker only — for natural language queries)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=your_supabase_db_url_here

# MCP API key (worker only — gates the /mcp endpoint)
MCP_API_KEY=your_mcp_api_key_here

# Perplexity API key — used for grounded reasoning validation in validate-predictions
# Get at: https://www.perplexity.ai/settings/api
# Optional: falls back to Claude-only scoring if absent
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Stripe pricing (VITE_ prefix required for frontend)
VITE_STRIPE_PRICE_PRO_MONTHLY=price_xxx
VITE_STRIPE_PRICE_PRO_YEARLY=price_xxx
VITE_STRIPE_PRICE_ENTERPRISE_MONTHLY=price_xxx
VITE_STRIPE_PRICE_ENTERPRISE_YEARLY=price_xxx

# Worker URL (Fly.io — used by frontend for swarm triggers and Yahoo Finance data)
VITE_WORKER_URL=https://streetinsights-worker.fly.dev

# Sentry (optional - error monitoring)
VITE_SENTRY_DSN=your_sentry_dsn_here
VITE_APP_VERSION=1.0.0

# Server-only secrets (worker process only, NOT exposed to browser)
# LLM providers (multi-model routing with fallback: Grok → GPT-4 → Claude → Gemini)
XAI_API_KEY=your_xai_api_key_here
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GOOGLE_API_KEY=your_google_key_here

# Market data
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
FMP_API_KEY=your_fmp_api_key_here

# News providers (multi-source with fallback: SerpAPI → Tavily → NewsAPI → SearXNG)
NEWS_API_KEY=your_news_api_key_here
SERPAPI_API_KEY=your_serpapi_key_here
TAVILY_API_KEY=your_tavily_key_here
SEARXNG_BASE_URL=https://searx.be

# Adanos Market Sentiment (Reddit + X + News + Polymarket aggregated)
# https://api.adanos.io — get key at adanos.org
ADANOS_API_KEY=your_adanos_api_key_here

# Social media
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here

# Email delivery (Resend)
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=alerts@getstreetinsights.com
DEFAULT_ALERT_EMAIL=your_email@example.com

# Multi-channel notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_discord_channel_id_here
SLACK_BOT_TOKEN=your_slack_bot_token_here
SLACK_CHANNEL_ID=your_slack_channel_id_here
